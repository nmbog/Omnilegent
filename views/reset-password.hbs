<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omnilegent</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.png">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
</head>
<body>
    <nav>
        <ul>
            <li>
                <a href="/login">Login</a>
            </li>
            <li>
                |
            </li>
            <li>
                <a href="/register">Register</a>
            </li>
        </ul>
    </nav>
    <div class="header">
        <img src="/images/Omnilegent-2.png" alt="Omnilegent logo" class="header-image">
    </div>
    <div class="form-container">
        <h2>Reset Your Password</h2>
        <form action="/reset-password" method="POST">
            <!-- Hidden field to hold the reset token -->
            <input type="hidden" name="resetToken" value="{{resetToken}}">

            <div>
                <label for="newPassword">New Password</label>
                <input class="password-reset" type="password" id="newPassword" name="newPassword" required>
            </div>
            <div>
                <button class="password-reset" type="submit">Submit</button>
            </div>
        </form>
        <p>Remembered your password? <a href="/login">Login</a></p>
    </div>
</body>
</html>