<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omnilegent</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.png">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
</head>
<body>
    <nav>
        <ul>
            <li>
                <a href="/logout">Logout</a>
            </li>
        </ul>
    </nav>
    <div class="header">
        <img src="/images/Omnilegent-2.png" alt="Omnilegent logo" class="header-image">
    </div>
    <div class="main-container">
        <h1>Search Results for "{{searchQuery}}"</h1>
    </div>
    {{#if searchResults.length}}
    <table class="search-results">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Genre</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {{#each searchResults}}
            <tr>
                <td>{{this.BookTitle}}</td>
                <td>{{this.AuthorFullName}}</td>
                <td>{{this.Genre}}</td>
                <td>
                    <!-- Form to Add Book to Tracked List -->
                    <form method="POST" action="/search-add-book" class="tracked-book-form">
                        <input type="hidden" name="action" value="add" />
                        <input type="hidden" name="ISBN" value="{{this.ISBN}}" />
                        <div class="form-group">
                            <label for="readingStatus">Status:</label>
                            <select name="readingStatus" required>
                                <option value="Not Started">Not Started</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Completed">Completed</option>
                                <option value="Did Not Finish">Did Not Finish</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="startDate">Start:</label>
                            <input type="date" name="startDate" />
                        </div>
                        <div class="form-group">
                            <label for="finishDate">Finish:</label>
                            <input type="date" name="finishDate" />
                        </div>
                        <button class="tracked-submit" type="submit">Add to Tracked</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <div class="main-container">
        <p>No books found for "{{searchQuery}}".</p>
    </div>

    <!-- Form to Add a New Book -->
    <div class="form-container">
        <h2>Add a New Book</h2>
        <form action="/add-new-book" method="POST">
            <label for="ISBN">ISBN:</label>
            <input class="add-book" type="text" id="ISBN" name="ISBN" required>

            <label for="title">Title:</label>
            <input class="add-book" type="text" id="title" name="title" required>

            <label for="author">Author:</label>
            <input class="add-book" type="text" id="author" name="author" required>

            <label for="genre">Genre:</label>
            <input class="add-book" type="text" id="genre" name="genre" required>

            <label for="readingStatus">Status:</label>
            <select class="add-book" id="readingStatus" name="readingStatus">
                <option value="">--Select--</option>
                <option value="Completed">Completed</option>
                <option value="In Progress">In Progress</option>
                <option value="Not Started">Not Started</option>
                <option value="Did Not Finish">Did Not Finish</option>
            </select>

            <label for="startDate">Start:</label>
            <input class="add-book" type="date" id="startDate" name="startDate">

            <label for="finishDate">Finish:</label>
            <input class="add-book" type="date" id="finishDate" name="finishDate">

            <button type="submit">Add Book</button>
        </form>
        {{/if}}
        <br>
        <br>
    </div>
    <!-- Back to User's Tracked Books -->
    <div class="main-container">
        <a href="/protected">Take me back to my books!</a>
    </div>
    <div class="footer">
        &copy; <a href="mailto:trackomnilegent@gmail.com">Nicole Bogart</a> 2024
    </div>
</body>
</html>
