<!-- register.hbs -->
<!DOCTYPE html>
<html lang="en">
<head>
        <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Omnilegent</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.png">
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="header">
        <img src="/images/Omnilegent-2.png" alt="Omnilegent logo" class="header-image">
    </div>
    <div class="main-container">
        <h1 class="color">Register</h1>
    </div>
    <div class="form-container">
        <form action="/register" method="POST">
            <div>
                <label for="username">Username:</label>
                <input class="register" type="text" id="username" name="username" required>
            </div>
            <div>
                <label for="email">Email:</label>
                <input class="register" type="email" id="email" name="email" required>
            </div>
            <div>
                <label for="userPassword">Password</label>
                <input class="register" type="password" id="userPassword" name="userPassword" required>
            </div>
            <div>
                <button class="register" type="submit" id="register-button">Register</button>
            </div>
        </form>
        <p>Already have an account? <a href="/login">Login</a></p>
    </div>
    <div class="footer">
        &copy; <a href="mailto:nicole@omnilegent.co">Nicole Bogart</a> 2024
    </div>
</body>
</html>